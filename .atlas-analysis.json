  "publicApiSurface": [
    "track(name, properties) - Track custom events",
    "flush() - Force send queued events",
    "clear() - Clear user session",
    "getAnonymousId() - Get anonymous user ID",
    "getSessionId() - Get current session ID",
    "trackError(message, properties) - Track errors",
    "POST /api/events/track - Track events via API",
    "POST /api/events/batch - Batch track multiple events",
    "GET /api/analytics/pageviews - Get pageview analytics",
    "GET /api/analytics/events - Query event data",
    "GET /api/analytics/sessions - Get session analytics",
    "POST /api/links/create - Create short link",
    "GET /api/links/:id/analytics - Get link analytics",
    "POST /api/uptime/monitors - Create uptime monitor",
    "GET /api/uptime/:id/status - Get uptime status",
    "useDatabuddy() - React hook for tracking",
    "DatabuddyProvider - React context provider",
    "useFlags() - React hook for feature flags"
  ]
